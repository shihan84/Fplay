generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Channel {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("stopped") // stopped, starting, running, error
  color       String   @default("#ef4444")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings    ChannelSettings?
  playlists   Playlist[]
  media       ChannelMedia[]
  logs        AsRunLog[]
  logos       LogoOverlay[]
  textOverlays TextOverlay[]
  graphics    GraphicsOverlay[]
}

model TextOverlay {
  id           String   @id @default(cuid())
  channelId    String
  channel      Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  name         String   @default("")
  type         String   @default("static")  // static | ticker | clock | lowerthird
  active       Boolean  @default(true)

  // Content
  text         String   @default("")
  fontFile     String   @default("")        // path to .ttf font or empty for built-in
  fontSize     Int      @default(32)
  fontColor    String   @default("white")
  bgColor      String   @default("")        // empty = transparent background
  bgOpacity    Float    @default(0.5)
  outline      Int      @default(2)         // outline/border width in px
  outlineColor String   @default("black")

  // Position (for static/clock/lowerthird)
  posX         String   @default("center")  // left|center|right or pixel value
  posY         String   @default("bottom")  // top|center|bottom or pixel value
  offsetX      Int      @default(0)
  offsetY      Int      @default(40)

  // Ticker specific
  scrollSpeed  Int      @default(100)       // pixels per second

  // Lower third specific
  subText      String   @default("")        // second line
  subFontSize  Int      @default(22)

  // Schedule
  startTime    String   @default("")
  endTime      String   @default("")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChannelSettings {
  id              String  @id @default(cuid())
  channelId       String  @unique
  channel         Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  // Video settings
  width           Int     @default(1920)
  height          Int     @default(1080)
  fps             Float   @default(25.0)
  videoCodec      String  @default("libx264")
  videoBitrate    Int     @default(4500) // kbps
  videoPreset     String  @default("medium")
  videoProfile    String  @default("high")
  gopSize         Int     @default(50)
  keyframeInt     Int     @default(2)

  // Audio settings
  audioCodec      String  @default("aac")
  audioBitrate    Int     @default(128) // kbps
  audioSampleRate Int     @default(48000)
  audioChannels   Int     @default(2)
  loudnessNorm    Boolean @default(false)
  loudnessTarget  Float   @default(-23.0)

  // MPEG-TS PID settings (used when outputFormat is mpegts)
  videoPid        Int     @default(256)   // 0x0100
  audioPid        Int     @default(272)   // 0x0110
  pmtPid          Int     @default(4096)  // 0x1000

  // Output settings
  outputFormat    String  @default("mpegts")
  outputProtocol  String  @default("rtmp")
  outputUrl       String  @default("")
  outputKey       String  @default("")
  customOutput    String  @default("")

  // Playout settings
  loopPlaylist    Boolean @default(true)
  autoRecover     Boolean @default(true)
  fillerMode      String  @default("black") // black, image, playlist
  fillerPath      String  @default("")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Media {
  id          String   @id @default(cuid())
  filename    String
  title       String?
  path        String
  fileType    String   @default("video") // video, audio, image
  fileSize    Int      @default(0)
  duration    Float    @default(0)
  resolution  String?
  codec       String?
  bitrate     Int      @default(0)
  frameRate   Float?
  sampleRate  Int?
  channels    Int?
  category    String?
  tags        String?  // JSON array stored as string
  thumbnail   String?
  status      String   @default("ready") // ready, processing, error
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channelLinks ChannelMedia[]
  playlistItems PlaylistItem[]
}

model ChannelMedia {
  id        String  @id @default(cuid())
  channelId String
  mediaId   String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  media     Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([channelId, mediaId])
}

model Playlist {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean  @default(false)
  loop      Boolean  @default(true)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     PlaylistItem[]
}

model PlaylistItem {
  id          String   @id @default(cuid())
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  mediaId     String
  media       Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  title       String
  artist      String?
  duration    Float    @default(0)
  order       Int      @default(0)
  transition  String   @default("cut") // cut, crossfade, fade-through-white, fade-through-black, dissolve
  transitionDur Float  @default(1.0)
  inPoint     Float    @default(0)
  outPoint    Float?
  customText  String?
  status      String   @default("pending") // pending, playing, played, error
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AsRunLog {
  id          String   @id @default(cuid())
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  playlistId  String?
  mediaId     String?
  title       String
  duration    Float    @default(0)
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  status      String   @default("success") // success, error, skipped
  error       String?
  createdAt   DateTime @default(now())
}

model LogoOverlay {
  id        String  @id @default(cuid())
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String
  path      String
  opacity   Float   @default(1.0)
  posX      String  @default("right")
  posY      String  @default("top")
  offsetX   Int     @default(20)
  offsetY   Int     @default(20)
  sizeW     Int     @default(200)
  sizeH     Int     @default(0) // 0 = auto
  active    Boolean @default(true)
  bgColor   String?  // hex color to key out (e.g. #5e5e5e) for JPEG logos
  category  String?
  startTime String?  // HH:MM:SS - when to show
  endTime   String?  // HH:MM:SS - when to hide
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GraphicsOverlay {
  id        String  @id @default(cuid())
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String
  html      String  @default("")
  css       String  @default("")
  position  String  @default("bottom-left")
  duration  Float   @default(5.0)
  active    Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DomainConfig {
  id         String   @id @default(cuid())
  domain     String   @unique
  sslEnabled Boolean  @default(true)
  sslStatus  String   @default("none") // none, pending, active, error
  sslExpiry  DateTime?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}