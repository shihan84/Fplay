# ===========================================
# ffplayout - Environment Configuration
# ===========================================
# Copy this file to .env and adjust values.

# ── Database ──────────────────────────────
DATABASE_URL="file:/data/custom.db"

# ── Next.js ───────────────────────────────
NODE_ENV=production
PORT=3000

# ── Docker Ports ──────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Domain (for Caddy auto-HTTPS) ─────────
# Set to your domain to enable automatic SSL.
# Leave as "localhost" for local HTTP only.
DOMAIN=localhost